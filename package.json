{
  "name": "mikro-orm-better-auth",
  "version": "0.0.0-development",
  "description": "Better Auth adapter for MikroORM with ts-morph entity generation.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "typecheck": "tsc --project tsconfig.json",
    "test": "vitest run",
    "test:generate": "pnpm dlx auth@latest generate --config test/fixtures/auth.ts --output tmp/entities --yes",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "semantic-release": "semantic-release"
  },
  "keywords": [
    "better-auth",
    "mikro-orm",
    "adapter",
    "authentication"
  ],
  "author": "Xudong Huang <me@huangxudong.com>",
  "license": "ISC",
  "homepage": "https://github.com/xudongcc/mikro-orm-better-auth#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/xudongcc/mikro-orm-better-auth.git"
  },
  "bugs": {
    "url": "https://github.com/xudongcc/mikro-orm-better-auth/issues"
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@better-auth/test-utils": "^1.5.5",
    "@eslint/js": "^10.0.1",
    "@mikro-orm/core": "^6.6.9",
    "@mikro-orm/knex": "^6.6.9",
    "@mikro-orm/sqlite": "6.6.9",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "better-auth": "^1.5.5",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@mikro-orm/core": "^6.0.0",
    "@mikro-orm/knex": "^6.0.0",
    "better-auth": "^1.0.0",
    "prettier": "^3.0.0",
    "ts-morph": "^27.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sqlite3"
    ]
  },
  "volta": {
    "node": "24.14.0"
  }
}
